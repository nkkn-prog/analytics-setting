# ===================================================================
# Claude 呼び出しプロバイダ
#   agent-sdk : Claude Agent SDK 経由（サブスクリプション認証 / 推奨）
#               → ANTHROPIC_API_KEY を「設定しない」こと
#               → 事前に `claude` CLI で /login しておく
#   api       : Anthropic API 経由（API キー課金）
# 未指定時のデフォルトは agent-sdk
# ===================================================================
CLAUDE_PROVIDER=agent-sdk

# Anthropic API キー（CLAUDE_PROVIDER=api のときのみ必須）
# サブスクリプション運用時はこの行をコメントアウト or 空のままにすること
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ===================================================================
# GA4 Data API（business-context.json の dataSource=ga4-api のときのみ必須）
#
# GCP Console (https://console.cloud.google.com/) で:
#   1. 任意のプロジェクトを選択
#   2. APIとサービス → ライブラリ → "Google Analytics Data API" を有効化
#   3. APIとサービス → 認証情報 → "OAuth クライアント ID を作成"
#      - アプリケーションの種類: デスクトップアプリ
#   4. 発行されたクライアントIDとシークレットを以下に貼り付け
#
# 初回利用時に `npm run ga4:login` を実行すると、ブラウザで Google ログインが開き、
# 取得したリフレッシュトークンが .cache/ga4-token.json に保存されます。
#
# 親プロジェクト (analytics-setting) と同じ OAuth クライアントを再利用したい場合は、
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET でも認識します（GA4_OAUTH_* が優先）。
# ===================================================================
# GA4_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GA4_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxx
